# Local machine configuration for oracle-owned Elixir tasks.
#
# Copy to priv/env/env.local for local use. env.local is gitignored.
# Values may also be supplied by the caller environment.

NXPLATFORM_WORKSPACE_ROOT=/Users/me/wip-mach
NXPLATFORM_FREEBSD_SRC=/Users/me/wip-mach/wip-gpt/freebsd-src-stable-15

# Objdir prefixes are lane-specific configured inputs. These example values are
# observed legacy values only; pin the correct values for the lane you run.
NXPLATFORM_KERNEL_OBJDIRPREFIX_CURRENT_TREE=/Users/me/wip-mach/build/releng151-rc1-mach-obj
NXPLATFORM_KERNEL_OBJDIRPREFIX_LAUNCHD=/Users/me/wip-mach/build/releng151-mach-obj
NXPLATFORM_KERNEL_OBJDIRPREFIX_DISPATCH=/usr/obj
NXPLATFORM_KERNEL_OBJDIRPREFIX_LIBTHR=/usr/obj

# Optional donor/reference roots. Required only when donor material is consumed.
# NXPLATFORM_DONOR_MACH_TESTS_ROOT=/Users/me/wip-mach/nx/NextBSD/usr.bin/mach-tests
# NXPLATFORM_DONOR_LIBMACH_TEST_ROOT=/Users/me/wip-mach/nx/NextBSD/lib/libmach/test
# NXPLATFORM_DONOR_XPC_TESTS_ROOT=/Users/me/wip-mach/nx/NextBSD/usr.bin/xpc-tests

# Optional provenance label for future runs.
# NXPLATFORM_BASE_PROFILE=stable15-candidate
