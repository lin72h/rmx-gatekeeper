# Local machine configuration for oracle-owned Elixir tasks.
#
# Copy to priv/env/env.local for local use. env.local is gitignored.
# Values may also be supplied by the caller environment.

NXPLATFORM_WORKSPACE_ROOT=/Users/me/wip-mach
NXPLATFORM_FREEBSD_SRC=/Users/me/wip-mach/freebsd-src-official-stable-15

# Objdir prefixes are lane-specific configured inputs. The default source
# profile is stable15-active, so selected lane prefixes must point at the
# official stable/15 candidate objdir unless an explicit fallback profile is set.
NXPLATFORM_KERNEL_OBJDIRPREFIX_CURRENT_TREE=/Users/me/wip-mach/build/official-stable15-mach-obj
NXPLATFORM_KERNEL_OBJDIRPREFIX_LAUNCHD=/Users/me/wip-mach/build/official-stable15-mach-obj
NXPLATFORM_KERNEL_OBJDIRPREFIX_DISPATCH=/Users/me/wip-mach/build/official-stable15-mach-obj
NXPLATFORM_KERNEL_OBJDIRPREFIX_LIBTHR=/Users/me/wip-mach/build/official-stable15-mach-obj

# Optional donor/reference roots. Required only when donor material is consumed.
# NXPLATFORM_DONOR_MACH_TESTS_ROOT=/Users/me/wip-mach/nx/NextBSD/usr.bin/mach-tests
# NXPLATFORM_DONOR_LIBMACH_TEST_ROOT=/Users/me/wip-mach/nx/NextBSD/lib/libmach/test
# NXPLATFORM_DONOR_XPC_TESTS_ROOT=/Users/me/wip-mach/nx/NextBSD/usr.bin/xpc-tests

# Optional provenance label for future runs. If unset, env resolution uses
# stable15-active. releng151-current remains an explicit fallback.
# NXPLATFORM_BASE_PROFILE=stable15-active
